---
const year = 2026;
---

<footer class="border-t-[3px] border-ink bg-ink px-5 py-10 text-paper sm:px-7">
  <div
    class="mx-auto flex max-w-[1280px] flex-wrap items-center justify-between gap-[18px]"
  >
    <a href="/" class="flex items-center gap-2.5">
      <span class="font-display text-[28px] font-extrabold tracking-[-1px]">SPUT</span>
      <span class="anim-pulse inline-block h-[13px] w-[13px] rounded-full bg-mag"></span>
    </a>
    <p class="font-mono text-[12px] uppercase tracking-[1px] opacity-60">
      © {year} Robert "Sput" Searight · Keep the groove
    </p>
  </div>
</footer>
