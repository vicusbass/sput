---
import Layout from "../layouts/Layout.astro";
import { HERO_WORDS, MARQUEE_ARTISTS, FEATURE_TILES } from "../data/site";

const eqBars = [
  { c: "mag", d: "0.9s", delay: "0s" },
  { c: "teal", d: "0.7s", delay: ".1s" },
  { c: "mar", d: "1.1s", delay: ".2s" },
  { c: "tang", d: "0.8s", delay: ".15s" },
  { c: "violet", d: "1s", delay: ".05s" },
  { c: "teal", d: "0.75s", delay: ".25s" },
  { c: "mag", d: "0.95s", delay: ".3s" },
  { c: "mar", d: "0.85s", delay: ".12s" },
];
const starColors = ["mar", "teal", "mag"];
const tileBg: Record<string, string> = { mar: "bg-mar", mag: "bg-mag", teal: "bg-teal" };
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden px-5 pt-[54px] sm:px-7">
    <!-- floating sticker -->
    <div
      class="anim-drift absolute right-[8%] top-[60px] z-[3] hidden h-24 w-24 items-center justify-center rounded-full border-[3px] border-ink bg-teal text-center font-mono text-[11px] font-bold leading-[1.1] text-ink md:flex"
      style="--r:-12deg; transform:rotate(-12deg);"
    >
      SINCE<br />'08
    </div>

    <div
      class="relative mx-auto grid max-w-[1280px] items-center gap-9 md:grid-cols-[1.15fr_.85fr]"
    >
      <div>
        <div
          class="mb-6 inline-flex items-center gap-2.5 border-[3px] border-ink bg-mar px-3.5 py-[7px] font-mono text-[12px] font-bold uppercase tracking-[2px] shadow-[4px_4px_0_var(--color-ink)]"
        >
          <span class="anim-pulse inline-block h-[9px] w-[9px] rounded-full bg-ink"></span>
          Drummer · Producer · Bandleader
        </div>

        <h1
          class="mb-3 font-display text-[clamp(40px,8vw,120px)] font-extrabold uppercase leading-[.86] tracking-[-3px] md:mb-8"
        >
          Robert<br />
          <span class="text-mag [-webkit-text-stroke:3px_var(--color-ink)]">"Sput"</span><br />
          Searight
        </h1>

        <p
          class="flex flex-col items-start gap-2.5 font-display text-[clamp(22px,3vw,40px)] font-bold uppercase tracking-[-1px] sm:flex-row sm:flex-wrap sm:items-baseline sm:gap-3.5"
        >
          <span class="opacity-55">It's all about</span>
          <span
            id="hero-word"
            class="inline-block border-[3px] border-ink bg-teal px-3.5 py-0.5"
            style="transform:rotate(-1.5deg);">{HERO_WORDS[0]}</span
          >
        </p>

        <div class="mt-[34px] flex flex-wrap gap-3.5">
          <a
            href="/tour"
            class="border-[3px] border-ink bg-ink px-[26px] py-[15px] font-mono text-[14px] font-bold uppercase tracking-[1px] text-paper shadow-[5px_5px_0_var(--color-mag)] transition-transform duration-150 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[8px_8px_0_var(--color-mag)]"
            >See Tour Dates →</a
          >
          <a
            href="/collabs"
            class="border-[3px] border-ink bg-transparent px-[26px] py-[15px] font-mono text-[14px] font-bold uppercase tracking-[1px] text-ink transition-colors duration-150 hover:bg-mar"
            >The Collab Map</a
          >
        </div>
      </div>

      <div class="relative">
        <div class="absolute -left-3.5 -top-3.5 bottom-3.5 right-3.5 border-[3px] border-ink bg-mar"></div>
        <div class="relative aspect-[4/5] overflow-hidden border-[3px] border-ink bg-panel">
          <img
            src="/sput-hero.jpg"
            alt={'Robert "Sput" Searight behind the kit'}
            width="640"
            height="800"
            class="block h-full w-full object-cover"
          />
        </div>
        <div
          class="anim-spin absolute -bottom-[22px] -right-[18px] z-[4] hidden h-[120px] w-[120px] items-center justify-center rounded-full bg-ink md:flex"
        >
          <span class="font-mono text-[9px] font-bold uppercase tracking-[2px] text-paper"
            >★ funk ★ feel ★</span
          >
          <span class="absolute h-[18px] w-[18px] rounded-full border-2 border-paper bg-mag"></span>
        </div>
      </div>

      <!-- equalizer -->
      <div class="absolute bottom-0 right-0 hidden h-[46px] w-[20%] items-end gap-1.5 md:flex">
        {
          eqBars.map((b) => (
            <span
              class:list={["h-full flex-1 origin-bottom", tileBg[b.c] ?? `bg-${b.c}`]}
              style={`background:var(--${b.c}); animation:eq ${b.d} ease-in-out infinite ${b.delay};`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE ============ -->
  <section class="mt-[46px] overflow-hidden border-y-[3px] border-ink bg-ink py-3.5">
    <div
      class="anim-marq flex w-max whitespace-nowrap font-display text-[20px] font-extrabold uppercase text-paper sm:text-[34px]"
    >
      {
        [0, 1].map(() => (
          <span class="px-6">
            {MARQUEE_ARTISTS.map((a, i) => (
              <>
                {a}
                <span style={`color:var(--${starColors[i % 3]})`}>{" ✸ "}</span>
              </>
            ))}
          </span>
        ))
      }
    </div>
  </section>

  <!-- ============ PHILOSOPHY ============ -->
  <section data-reveal class="mx-auto max-w-[1080px] px-5 py-[90px] text-center sm:px-7">
    <p class="mb-[22px] font-mono text-[13px] font-bold uppercase tracking-[3px] text-tang">
      // The Philosophy
    </p>
    <p class="font-display text-[clamp(28px,4.4vw,56px)] font-bold leading-[1.02] tracking-[-1.5px]">
      Groove first. Always. The pocket is a <span class="text-mag">conversation</span> — and Sput's
      been the one keeping the whole band <span
        class="bg-mar px-2"
        style="box-decoration-break:clone;-webkit-box-decoration-break:clone;">honest</span
      > for two decades.
    </p>
  </section>

  <!-- ============ FEATURE TILES ============ -->
  <section
    class="mx-auto grid max-w-[1280px] grid-cols-1 gap-[22px] px-5 pb-[90px] sm:px-7 md:grid-cols-3"
  >
    {
      FEATURE_TILES.map((t, i) => (
        <a
          href={t.href}
          data-reveal
          data-delay={i * 90}
          class:list={[
            "flex min-h-[280px] flex-col justify-between border-[3px] border-ink p-[30px] shadow-[6px_6px_0_var(--color-ink)] transition-transform duration-150 hover:-translate-x-[3px] hover:-translate-y-[3px] hover:shadow-[9px_9px_0_var(--color-ink)]",
            tileBg[t.bg],
          ]}
        >
          <span class="font-mono text-[12px] font-bold uppercase tracking-[2px]">{t.index}</span>
          <span
            class:list={[
              "font-display text-[40px] font-extrabold uppercase leading-[.95]",
              "invert" in t && t.invert ? "text-paper" : "",
            ]}
          >
            {t.title}
          </span>
        </a>
      ))
    }
  </section>
</Layout>

<script>
  // Rotating hero word
  const WORDS = ["THE POCKET", "THE GROOVE", "THE FEEL", "THE FUNK"];
  const el = document.getElementById("hero-word");
  if (el) {
    let i = 0;
    setInterval(() => {
      i = (i + 1) % WORDS.length;
      el.textContent = WORDS[i];
    }, 1700);
  }
</script>
